{
  "mcpServers": {
    "jcodemunch": {
      "command": "uvx",
      "args": ["jcodemunch-mcp"],
      "env": {}
    },
    "reme": {
      "command": "reme",
      "args": [
        "backend=mcp",
        "mcp.transport=stdio",
        "vector_store.default.backend=local_file"
      ],
      "env": {}
    },
    "n8n": {
      "command": "npx",
      "args": ["-y", "n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "https://ai-yah-old.blowfish-snares.ts.net",
        "N8N_API_KEY": "${N8N_API_KEY}"
      }
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from", "git+https://github.com/oraios/serena",
        "serena", "start-mcp-server",
        "--context", "claude-code",
        "--project", "/home/kevin/projects/goodai"
      ]
    },
    "pal": {
      "command": "bash",
      "args": [
        "-c",
        "for p in $(which uvx 2>/dev/null) $HOME/.local/bin/uvx /usr/local/bin/uvx uvx; do [ -x \"$p\" ] && exec \"$p\" --from git+https://github.com/BeehiveInnovations/pal-mcp-server.git pal-mcp-server; done; echo 'uvx not found' >&2; exit 1"
      ],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "DEFAULT_MODEL": "auto"
      }
    },
    "mem0": {
      "command": "uvx",
      "args": ["mem0-mcp-server"],
      "env": {
        "MEM0_API_KEY": "${MEM0_API_KEY}",
        "MEM0_DEFAULT_USER_ID": "kevinktg"
      }
    },
    "in-memoria": {
      "command": "npx",
      "args": ["-y", "in-memoria", "server"]
    },
    "google-workspace": {
      "command": "npx",
      "args": ["-y", "google-workspace-mcp", "serve"]
    },
    "gws": {
      "command": "npx",
      "args": ["-y", "gws", "mcp"],
      "env": {}
    },
    "obsidian": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "http://localhost:22360/sse"],
      "env": {}
    },
    "notebooklm": {
      "command": "npx",
      "args": ["-y", "notebooklm-mcp"],
      "env": {}
    }
  }
}
